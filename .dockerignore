# Keep the build context small and secrets out of the image.
.git
.gitignore
**/node_modules
client/dist
shared-types/dist
shared-utils/dist
**/.vite
*.log
logs/
.env
.env.*
deploy/
run.sh
Dockerfile.monorepo
README.md

# Piper binary + voices are fetched inside the Dockerfile, not copied from context
assets/piper/voices
assets/piper/*.so*
assets/piper/espeak-ng-data
assets/piper/piper
assets/piper/piper_phonemize
assets/piper/espeak-ng
assets/piper/libtashkeel_model.ort
assets/piper/pkgconfig
