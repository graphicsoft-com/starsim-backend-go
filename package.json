{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"yellow,cyan\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npx tsx watch src/main.ts",
    "dev:client": "npx wait-on http://localhost:3000/api/simulation/status -t 60000 && vite --config client/vite.config.mts",
    "build": "npm run build:client && npm run build:server",
    "build:server": "webpack --config server/webpack.config.js --mode production",
    "build:client": "vite build --config client/vite.config.mts",
    "start": "cd server && node dist/main.js"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.0",
    "ajv": "^8.0.0",
    "autoprefixer": "10.4.13",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^12.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "react-refresh": "^0.10.0",
    "tailwindcss": "3.4.3",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^4.0.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "workspaces": [
    "packages/*",
    "client",
    "shared-types",
    "shared-utils"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "mongoose": "^9.2.1",
    "node-cron": "^4.2.1",
    "openai": "^6.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
