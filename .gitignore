# ─── Secrets / environment ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Go build artifacts ──────────────────────────────────────────────────────
# Compiled binary (module name "starsim") and any other binaries
/starsim
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace / vendor
/vendor/
go.work
go.work.sum

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Node / client workspace (copied in for the Docker build) ────────────────
node_modules/
**/node_modules/
client/dist/
shared-types/dist/
shared-utils/dist/
.vite/

# ─── TTS runtime artifacts ───────────────────────────────────────────────────
*.wav
tmp/
*.tmp

# ─── Piper binary, bundled libs, espeak data, voice models (~930MB) ──────────
# Downloadable artifacts — fetch with assets/piper/install-piper.sh; the
# Dockerfile also fetches them at build time. Keep only the installer tracked.
assets/piper/*
!assets/piper/install-piper.sh

# ─── OS / editor cruft ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
